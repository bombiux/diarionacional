    "timber/timber": "^2.3",
    "vlucas/phpdotenv": "^5.6",
    "resend/resend-php": "^1.1",
    "meilisearch/meilisearch-php": "^1.16",
    "jgrossi/corcel": "^6.0",
    "nesbot/carbon": "^2.0",
    "htmlburger/carbon-fields": "^3.6"
  },
  "config": {
    "allow-plugins": {
      "php-http/discovery": true
    }
  },
  "autoload": {
