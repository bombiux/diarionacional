{% extends 'base.twig' %}

{% block content %}
<div class="max-w-7xl mx-auto pt-8 pb-24">

    {# ============================== #}
    {# Archive Header                 #}
    {# ============================== #}
    <header class="mb-16">
        {# Breadcrumbs #}
        <nav class="flex items-center gap-2 mb-8">
            <a href="{{ site.url }}" class="label-pulse text-on-surface/40 hover:text-primary transition-colors">Inicio</a>
            <span class="text-on-surface/20">{{ icon('chevron-right', 'w-3 h-3')|raw }}</span>
            <span class="label-pulse text-on-surface">{{ category.name|default('Archivo') }}</span>
        </nav>

        {# Title area with accent #}
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-8">
            <div class="space-y-4">
                <div class="flex items-center gap-4">
                    <div class="w-14 h-14 rounded-DEFAULT bg-surface-container-high flex items-center justify-center text-primary">
                        {% set icon_name = 'folder' %}
                        {% if category.taxonomy == 'category' %}
                            {% if 'nacional' in category.slug %}{% set icon_name = 'globe-americas' %}
                            {% elseif 'internacional' in category.slug %}{% set icon_name = 'globe' %}
                            {% elseif 'historia' in category.slug %}{% set icon_name = 'clock-history' %}
                            {% elseif 'discurso' in category.slug %}{% set icon_name = 'mic' %}
                            {% elseif 'eco' in category.slug %}{% set icon_name = 'cash-stack' %}
                            {% elseif 'analisis' in category.slug %}{% set icon_name = 'graph-up' %}
                            {% elseif 'testimonio' in category.slug %}{% set icon_name = 'book' %}
                            {% elseif 'destacada' in category.slug %}{% set icon_name = 'star-fill' %}
                            {% endif %}
                        {% elseif category.taxonomy == 'post_tag' %}
                            {% set icon_name = 'tag' %}
                        {% endif %}
                        {{ icon(icon_name, 'w-7 h-7')|raw }}
                    </div>
                    <div>
                        <span class="label-pulse text-tertiary">
                            {% if category.taxonomy == 'category' %}Categoría{% elseif category.taxonomy == 'post_tag' %}Etiqueta{% else %}Archivo{% endif %}
                        </span>
                        <h1 class="text-4xl lg:text-5xl font-headline font-extrabold tracking-tight text-on-surface">
                            {{ category.name|default('Archivo') }}
                        </h1>
                    </div>
                </div>
                {% if archive_description %}
                    <p class="text-on-surface/60 text-lg max-w-2xl leading-relaxed font-sans">{{ archive_description|raw }}</p>
                {% endif %}
            </div>

            {# Post count badge #}
            <div class="pill-nav-glass bg-surface-container-low border-none shadow-none">
                {{ icon('newspaper', 'w-5 h-5 text-primary')|raw }}
                <span class="text-sm font-bold text-on-surface">{{ total_posts }}</span>
                <span class="label-pulse text-on-surface/40 text-[10px]">artículos</span>
            </div>
        </div>
    </header>

    {# ============================== #}
    {# Featured Post (Page 1 only)    #}
    {# ============================== #}
    {% if featured_post and not posts.pagination.current or posts.pagination.current == 1 %}
    <section class="relative w-full h-[500px] rounded-DEFAULT overflow-hidden shadow-2xl mb-24 group card-pulse border-none">
        <img
            src="{{ featured_post.thumbnail.src('diario-nacional-hero')|default('https://images.unsplash.com/photo-1450101499163-c8848c66ca85?q=80&w=2070') }}"
            alt="{{ featured_post.title }}"
            class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105">
        <div class="absolute inset-0 bg-gradient-to-t from-on-surface via-on-surface/20 to-transparent"></div>
        <div class="absolute bottom-0 left-0 p-8 lg:p-16 w-full lg:max-w-3xl">
            <div class="flex items-center gap-4 mb-6">
                <span class="badge-pill bg-primary text-white">{{ category.name|default('Destacado') }}</span>
                <span class="label-pulse text-white/60">{{ featured_post.date|date('d M Y') }}</span>
            </div>
            <h2 class="text-3xl lg:text-5xl font-headline font-extrabold text-white tracking-tight mb-6 leading-tight">{{ featured_post.title }}</h2>
            <div class="flex items-center gap-6">
                <a href="{{ featured_post.link }}" class="btn-primary-gradient px-8 py-3 text-sm">
                    Leer artículo
                </a>
                <span class="label-pulse text-white/40">Por {{ featured_post.author.name }}</span>
            </div>
        </div>
    </section>
    {% endif %}

    {# ============================== #}
    {# Posts Grid                      #}
    {# ============================== #}
    {% if posts|length > 0 %}
    <section>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
            {% for post in posts %}
                {# Skip the featured post on page 1 #}
                {% if not (featured_post and loop.first and (not posts.pagination.current or posts.pagination.current == 1)) %}
                    {% include 'partials/card-news.twig' with { post: post } %}
                {% endif %}
            {% endfor %}
        </div>

        {# ============================== #}
        {# Pagination                      #}
        {# ============================== #}
        {% if posts.pagination.pages|length > 1 %}
        <nav class="flex justify-center items-center gap-3 mt-24" aria-label="Paginación">
            {% if posts.pagination.prev %}
            <a href="{{ posts.pagination.prev.link }}"
               class="w-12 h-12 rounded-full bg-surface-container-low flex items-center justify-center text-on-surface/40 hover:text-primary hover:bg-surface-container-high transition-all"
               aria-label="Página anterior">
                {{ icon('chevron-left', 'w-5 h-5')|raw }}
            </a>
            {% endif %}

            {% for page in posts.pagination.pages %}
                {% if page.link %}
                <a href="{{ page.link }}"
                   class="w-12 h-12 rounded-full flex items-center justify-center text-sm font-bold transition-all {% if page.current %}bg-primary text-white shadow-lg shadow-primary/20{% else %}bg-surface-container-low text-on-surface/40 hover:bg-surface-container-high hover:text-primary{% endif %}">
                    {{ page.title }}
                </a>
                {% elseif page.current %}
                <span class="w-12 h-12 rounded-full flex items-center justify-center text-sm font-bold bg-primary text-white shadow-lg shadow-primary/20">{{ page.title }}</span>
                {% else %}
                <span class="w-12 h-12 rounded-full flex items-center justify-center text-sm text-on-surface/20">{{ page.title }}</span>
                {% endif %}
            {% endfor %}

            {% if posts.pagination.next %}
            <a href="{{ posts.pagination.next.link }}"
               class="w-12 h-12 rounded-full bg-surface-container-low flex items-center justify-center text-on-surface/40 hover:text-primary hover:bg-surface-container-high transition-all"
               aria-label="Página siguiente">
                {{ icon('chevron-right', 'w-5 h-5')|raw }}
            </a>
            {% endif %}
        </nav>
        {% endif %}
    </section>

    {% else %}
    {# Empty State #}
    <div class="flex flex-col items-center justify-center py-32 text-center">
        <div class="w-32 h-32 rounded-DEFAULT bg-surface-container-low flex items-center justify-center mb-8">
            {{ icon('folder-x', 'w-16 h-16 text-on-surface/10')|raw }}
        </div>
        <h2 class="text-3xl font-headline font-extrabold text-on-surface mb-4">No hay artículos disponibles</h2>
        <p class="text-on-surface/60 max-w-md mb-12 leading-relaxed font-sans">
            Aún no se han publicado artículos en esta sección. Explora otras categorías del periódico.
        </p>
        <a href="{{ site.url }}" class="btn-primary-gradient px-10 py-4">
            Volver al inicio
        </a>
    </div>
    {% endif %}

</div>
{% endblock %}
