{% extends "base.twig" %}

{% block content %}
    {# ========================================== #}
    {# THE ARCHITECTURAL PULSE: Hero Section     #}
    {# ========================================== #}
    <section class="mb-24 mt-8">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
            
            <!-- Large Featured Image (7 columns) -->
            <div class="lg:col-span-7 relative group">
                {% if hero_post %}
                <div class="aspect-[16/10] overflow-hidden rounded-DEFAULT shadow-2xl">
                    <img src="{{ hero_post.thumbnail.src('diario-nacional-hero')|default('https://images.unsplash.com/photo-1504711432869-efd597cdd04d?q=80&w=2070') }}" 
                         alt="{{ hero_post.title }}" 
                         class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105">
                </div>
                <!-- Floating Category Badge (Glassmorphism) -->
                <div class="absolute top-6 left-6 pill-nav-glass px-4 py-1.5 border-none shadow-xl">
                    <span class="label-pulse text-primary">{{ hero_post.terms('category')|first.name|default('Destacado') }}</span>
                </div>
                {% endif %}
            </div>

            <!-- Hero Text (5 columns) -->
            <div class="lg:col-span-5 space-y-8">
                <div class="space-y-4">
                    <span class="label-pulse text-tertiary">Lo más relevante</span>
                    <h1 class="text-4xl md:text-5xl lg:text-6xl font-headline font-extrabold tracking-[-0.03em] leading-[1.1] text-on-surface">
                        {{ hero_post.title }}
                    </h1>
                    <p class="text-on-surface/60 text-lg md:text-xl font-sans leading-relaxed max-w-lg">
                        {{ hero_post.excerpt|default(hero_post.content|striptags|slice(0, 160) ~ '...') }}
                    </p>
                </div>

                <div class="flex items-center gap-6 pt-4">
                    <a href="{{ hero_post.link }}" class="btn-primary-gradient px-8 py-4 text-lg">
                        Leer Noticia
                    </a>
                    <div class="flex flex-col">
                        <span class="label-pulse text-on-surface/40">Por</span>
                        <span class="font-bold text-on-surface">{{ hero_post.author.name }}</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {# ========================================== #}
    {# THE PULSE GRID: Tonal Sectioning          #}
    {# ========================================== #}
    <section class="section-alt -mx-6 px-6 py-24 rounded-3xl mb-24">
        <div class="max-w-7xl mx-auto">
            <div class="flex items-end justify-between mb-16">
                <div class="space-y-2">
                    <span class="label-pulse text-secondary">Nacionales</span>
                    <h2 class="text-3xl md:text-4xl font-headline font-extrabold text-on-surface">Información de Impacto</h2>
                </div>
                <div class="hidden md:flex gap-4">
                     <span class="badge-pill bg-primary text-white">Todo</span>
                     <span class="badge-pill bg-surface-container-highest text-on-surface/60 hover:text-primary cursor-pointer transition-colors">Nacional</span>
                     <span class="badge-pill bg-surface-container-highest text-on-surface/60 hover:text-primary cursor-pointer transition-colors">Tech</span>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                {% for post in posts_nacionales|slice(0, 3) %}
                    {% include "partials/card-editorial.twig" with {post: post} %}
                {% endfor %}
            </div>
        </div>
    </section>

    {# ========================================== #}
    {# SECONDARY PULSE: Asymmetric Layout        #}
    {# ========================================== #}
    <section class="pb-24">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
            <!-- Viral / Trending (4 cols) -->
            <div class="lg:col-span-4 space-y-8">
                <h3 class="text-2xl font-headline font-extrabold border-l-4 border-tertiary pl-6">Contenido Viral</h3>
                <div class="space-y-12">
                    {% for post in posts_viral|slice(0, 3) %}
                        <article class="group flex gap-6 items-start">
                            <span class="text-5xl font-headline font-extrabold text-surface-container-highest group-hover:text-tertiary/20 transition-colors leading-none">0{{ loop.index }}</span>
                            <div class="space-y-2">
                                <span class="label-pulse text-tertiary/60">{{ post.terms('category')|first.name|default('Viral') }}</span>
                                <h4 class="text-lg font-bold leading-tight group-hover:text-primary transition-colors">
                                    <a href="{{ post.link }}">{{ post.title }}</a>
                                </h4>
                            </div>
                        </article>
                    {% endfor %}
                </div>
            </div>

            <!-- Analysis & International (8 cols) -->
            <div class="lg:col-span-8">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                     {% if latest_analisis %}
                        <div class="md:col-span-2">
                             {% include "partials/card-editorial.twig" with {post: latest_analisis} %}
                        </div>
                     {% endif %}
                     {% for post in posts_internacionales|slice(0, 2) %}
                        {% include "partials/card-editorial.twig" with {post: post} %}
                     {% endfor %}
                </div>
            </div>
        </div>
    </section>

    {# ========================================== #}
    {# SOCIAL PULSE: Interest Sections           #}
    {# ========================================== #}
    <section class="section-alt -mx-6 px-6 py-24 rounded-3xl mb-24">
        <div class="max-w-7xl mx-auto">
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
                <!-- Ambiente -->
                <div class="space-y-8">
                    <div class="flex items-center gap-4">
                        <span class="p-2 rounded-lg bg-green-500/10 text-green-600">
                            {{ icon('tree-fill', 'w-5 h-5') }}
                        </span>
                        <h3 class="text-xl font-headline font-extrabold">Ambiente</h3>
                    </div>
                    <div class="space-y-6">
                        {% for post in posts_ambiente %}
                            {% include "partials/card-editorial.twig" with {post: post, compact: true} %}
                        {% endfor %}
                    </div>
                </div>

                <!-- Salud -->
                <div class="space-y-8">
                    <div class="flex items-center gap-4">
                        <span class="p-2 rounded-lg bg-red-500/10 text-red-600">
                            {{ icon('heart-pulse-fill', 'w-5 h-5') }}
                        </span>
                        <h3 class="text-xl font-headline font-extrabold">Salud</h3>
                    </div>
                    <div class="space-y-6">
                        {% for post in posts_salud %}
                            {% include "partials/card-editorial.twig" with {post: post, compact: true} %}
                        {% endfor %}
                    </div>
                </div>

                <!-- Agricultura -->
                <div class="space-y-8">
                    <div class="flex items-center gap-4">
                        <span class="p-2 rounded-lg bg-amber-500/10 text-amber-600">
                            {{ icon('sun-fill', 'w-5 h-5') }}
                        </span>
                        <h3 class="text-xl font-headline font-extrabold">Agricultura</h3>
                    </div>
                    <div class="space-y-6">
                        {% for post in posts_agricultura %}
                            {% include "partials/card-editorial.twig" with {post: post, compact: true} %}
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
    </section>

    {# ========================================== #}
    {# SPECIALTY GRID: Tech, Sports, Farandula   #}
    {# ========================================== #}
    <section class="pb-24">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
            <!-- Tech & Sports (8 cols) -->
            <div class="lg:col-span-8 space-y-12">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
                    <!-- Tecnología -->
                    <div class="space-y-6">
                        <h3 class="text-2xl font-headline font-extrabold flex items-center gap-3">
                            {{ icon('cpu', 'w-6 h-6 text-primary') }}
                            Tecnología
                        </h3>
                        {% for post in posts_tecnologia|slice(0, 1) %}
                            {% include "partials/card-editorial.twig" with {post: post} %}
                        {% endfor %}
                    </div>
                    <!-- Deportes -->
                    <div class="space-y-6">
                        <h3 class="text-2xl font-headline font-extrabold flex items-center gap-3">
                            {{ icon('trophy-fill', 'w-6 h-6 text-tertiary') }}
                            Deportes
                        </h3>
                        {% for post in posts_deportes|slice(0, 1) %}
                            {% include "partials/card-editorial.twig" with {post: post} %}
                        {% endfor %}
                    </div>
                </div>

                <!-- Farándula (Banner Horizontal) -->
                <div class="bg-surface-container-low p-8 rounded-3xl relative overflow-hidden group">
                    <div class="relative z-10 flex flex-col md:flex-row items-center gap-8">
                        <div class="flex-1 space-y-4 text-center md:text-left">
                            <span class="label-pulse text-primary">Farándula</span>
                            <h3 class="text-3xl font-headline font-extrabold">El mundo del espectáculo</h3>
                            <p class="text-on-surface/60">Sigue las últimas noticias de tus artistas favoritos y eventos sociales.</p>
                        </div>
                        <div class="grid grid-cols-2 gap-4 flex-1">
                            {% for post in posts_farandula|slice(0, 2) %}
                                <a href="{{ post.link }}" class="block group/item">
                                    <div class="aspect-square rounded-xl overflow-hidden mb-2">
                                        <img src="{{ post.thumbnail.src }}" class="w-full h-full object-cover transition-transform group-hover/item:scale-110">
                                    </div>
                                    <h4 class="text-sm font-bold leading-tight line-clamp-2">{{ post.title }}</h4>
                                </a>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            </div>

            <!-- Galleries Widget (4 cols) -->
            <div class="lg:col-span-4 bg-surface-container-low p-8 rounded-DEFAULT space-y-8 h-fit">
                <h3 class="label-pulse text-on-surface/40 uppercase tracking-widest text-xs">Galerías Recientes</h3>
                <div class="grid grid-cols-2 gap-4">
                    {% for gallery in latest_galleries %}
                        <a href="{{ gallery.link }}" class="aspect-square rounded-DEFAULT overflow-hidden relative group">
                            <img src="{{ gallery.cover_image.src|default('https://images.unsplash.com/photo-1542038784456-1ea8e935640e?q=80&w=2070') }}" 
                                 class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" 
                                 alt="{{ gallery.title }}">
                            <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                                {{ icon('camera-fill', 'w-6 h-6 text-white') }}
                            </div>
                        </a>
                    {% endfor %}
                </div>
                <button class="w-full btn-primary-gradient py-3 text-xs uppercase tracking-widest">
                    Ver Multimedia
                </button>
            </div>
        </div>
    </section>
{% endblock %}
