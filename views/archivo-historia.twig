{% extends 'base.twig' %}

{% block content %}
<!-- Archivo de Historia -->
<div class="max-w-6xl mx-auto pt-8 pb-24">

    <!-- Page Header -->
    <div class="mb-16">
        <div class="flex items-center gap-3 mb-4">
            {{ icon('book', 'w-8 h-8 text-primary')|raw }}
            <h1 class="text-4xl font-bold tracking-tight text-on-background">Archivo de Historia</h1>
        </div>
        <p class="text-lg text-slate-500 max-w-2xl">
            Relatos que forjaron nuestra identidad, cr&oacute;nicas del pasado y voces que preservan la memoria nacional.
        </p>
    </div>

    {# ============================== #}
    {# Historia                       #}
    {# ============================== #}
