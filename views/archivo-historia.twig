        <div class="flex items-center justify-between mb-8">
            <div class="flex items-center gap-3">
                {{ icon('clock-history', 'w-6 h-6 text-primary')|raw }}
                <h2 class="text-2xl font-bold text-on-surface">Historia</h2>
            </div>
            <a href="{{ site.url }}/category/historia" class="text-primary font-bold text-sm uppercase tracking-widest hover:underline">Ver todo</a>
        </div>
        {% if posts_historia %}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            {% for post in posts_historia %}
                {% include 'partials/card-news.twig' with { post: post, category: 'Historia' } %}
            {% endfor %}
        </div>
        {% else %}
        <p class="text-slate-400 italic">No hay art&iacute;culos disponibles en esta secci&oacute;n.</p>
        {% endif %}
    </section>

