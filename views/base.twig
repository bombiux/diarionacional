<!DOCTYPE html>
<html {{ site.language_attributes }} class="light">
	<head>
		<meta charset="{{ site.charset }}"/>
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<script>
			if (localStorage.getItem('darkMode') === 'true') {
document.documentElement.classList.add('dark');
} else {
document.documentElement.classList.remove('dark');
}
		</script>

		<style>
			/* CSS Crítico para evitar parpadeos (FOUC) */
			[x-cloak] {
				display: none !important;
			}

			/* Estabilizar tamaño de iconos antes de que Tailwind cargue */
			svg {
				display: inline-block;
				vertical-align: middle;
				shape-rendering: inherit;
				flex-shrink: 0;
			}
		</style>
		<link rel="icon" type="image/png" href="{{ theme.link }}/assets/img/favicon.png">
		
		{# Typography & Icons #}
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Manrope:wght@400;500;700;800;900&display=swap" rel="stylesheet">
		<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

		{{ function('wp_head') }}
	</head>
	<body
		class="{{ body_class }} bg-background min-h-screen text-on-surface dark:bg-zinc-900 dark:text-zinc-100 selection:bg-primary selection:text-white overflow-x-hidden antialiased" x-data="{
			            darkMode: localStorage.getItem('darkMode') === 'true',
			            mobileMenuOpen: false,
			            searchOpen: false,
			            searchQuery: '',
						// Login Modal State
						loginModalOpen: false,
						authLoading: false,
						authError: '',
						authSuccess: '',
						authForm: {
							username: '',
							password: '',
							remember: false
						},
			            init() {
			                this.$watch('darkMode', val => {
			                    localStorage.setItem('darkMode', val);
			                    document.documentElement.classList.toggle('dark', val);
			                })
			            },
						async submitLogin() {
							this.authLoading = true;
							this.authError = '';
							this.authSuccess = '';
							
							try {
								const formData = new FormData();
								formData.append('action', 'ajax_login');
								formData.append('username', this.authForm.username);
								formData.append('password', this.authForm.password);
								formData.append('remember', this.authForm.remember);
								formData.append('security', '{{ login_nonce }}');

								const response = await fetch('{{ ajax_url }}', {
									method: 'POST',
									body: formData
								});
								
								const result = await response.json();
								
								if (result.success) {
									this.authSuccess = result.data.message;
									setTimeout(() => {
										window.location.reload();
									}, 1000);
								} else {
									this.authError = result.data.message;
									this.authLoading = false;
								}
							} catch (error) {
								this.authError = 'Hubo un problema de conexión. Inténtalo de nuevo.';
								this.authLoading = false;
							}
						}
			        }" @keydown.escape.window="mobileMenuOpen = false; searchOpen = false" :class="{ 'overflow-hidden': mobileMenuOpen || searchOpen }">

		<!-- Skip to content (A11Y-05) -->
		<a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[200] focus:bg-primary focus:text-white focus:px-6 focus:py-3 focus:rounded-full focus:font-bold focus:text-sm focus:shadow-xl">Saltar al contenido</a>

		<!-- Architectural Pulse Header -->
		{% include "partials/header.twig" %}

		<!-- ============================== -->
		<!-- Main Content Canvas            -->
		<!-- ============================== -->
		<main id="main-content" class="pt-8 md:pt-16 pb-20">
			<div class="max-w-7xl mx-auto px-6">
				{% block content %}
					<p>A&uacute;n no hay contenido.</p>
				{% endblock %}
			</div>
		</main>

		<!-- Mobile Navigation Drawer -->
		{% include "partials/mobile-menu.twig" %}

		<!-- Footer -->
		{% include "partials/footer.twig" %}

		<!-- ============================== -->
		<!-- Search Overlay Modal           -->
		<!-- ============================== -->
		<div x-show="searchOpen" 
			 x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100" 
			 x-transition:leave="transition ease-in duration-200" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0" 
			 class="fixed inset-0 z-[100] flex items-start justify-center pt-32 px-6" @click.self="searchOpen = false" x-cloak>
			
			<!-- Backdrop -->
			<div class="absolute inset-0 bg-surface/90 backdrop-blur-2xl"></div>

			<!-- Search Container -->
			<div class="relative w-full max-w-3xl transform transition-all">
				<!-- Close -->
				<button @click="searchOpen = false" class="absolute -top-16 right-0 w-12 h-12 rounded-full bg-white flex items-center justify-center text-on-surface/40 hover:text-primary transition-colors shadow-2xl">
					{{ icon('x-lg', 'w-6 h-6') }}
				</button>

				<form action="{{ site.url }}" method="get" role="search" class="relative group">
					<span class="absolute left-6 top-1/2 -translate-y-1/2 text-primary">
						{{ icon('search', 'w-8 h-8') }}
					</span>
					<input type="search" name="s" x-model="searchQuery" 
						   placeholder="Explora las noticias de hoy..." 
						   class="w-full pl-18 pr-18 py-8 bg-white rounded-DEFAULT border-none text-2xl font-headline font-extrabold text-on-surface placeholder:text-on-surface/20 focus:ring-4 focus:ring-primary/5 shadow-2xl transition-all" 
						   autocomplete="off" required>
					<button type="button" x-show="searchQuery.length > 0" @click="searchQuery = ''" class="absolute right-6 top-1/2 -translate-y-1/2 p-2 text-on-surface/20 hover:text-primary transition-colors">
						{{ icon('x-circle-fill', 'w-6 h-6') }}
					</button>
				</form>

				<div class="mt-8 flex flex-wrap items-center gap-4 justify-center" x-show="searchQuery.length === 0">
					<span class="label-pulse text-tertiary">Tendencias:</span>
					{% for item in menu.get_items|slice(0, 4) %}
						<a href="{{ site.url }}/?s={{ item.title|url_encode }}" class="badge-pill bg-surface-container-low text-on-surface hover:bg-primary hover:text-white transition-all">{{ item.title }}</a>
					{% endfor %}
				</div>
			</div>
		</div>

		<!-- Login Modal -->
		{% include "partials/login-modal.twig" %}

		{{ function('wp_footer') }}
	</body>
</html>
