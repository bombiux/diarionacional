<article class="relative aspect-[4/5] rounded-[3.5rem] group shadow-2xl overflow-hidden bg-surface-container-lowest">
    <!-- Main Content Wrapper (Image + Overlay) -->
    <div class="absolute inset-0 z-0 bg-surface-container">
        {% if post.thumbnail and post.thumbnail.src %}
            <img src="{{ post.thumbnail.src('large')|default(post.thumbnail.src) }}" 
                 alt="{{ post.title }}" 
                 class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110">
        {% else %}
            <div class="w-full h-full bg-gradient-to-br from-slate-200 to-slate-300 dark:from-slate-700 dark:to-slate-800 flex items-center justify-center">
                {{ icon('image', 'w-24 h-24 text-on-surface/10') }}
            </div>
        {% endif %}
        <!-- Gradient Overlay -->
        <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/30 to-transparent"></div>
    </div>

    <!-- Top Badges -->
    <div class="absolute top-8 left-8 right-8 flex justify-between items-center z-20">
        {% set category = post.terms('category')|first %}
        {% if category %}
            <span class="px-6 py-2 border border-white/40 rounded-full text-white text-xs font-bold uppercase tracking-widest backdrop-blur-md">
                {{ category.name }}
            </span>
        {% endif %}
        <div class="px-6 py-2 bg-white/20 backdrop-blur-md rounded-full text-white text-xs font-bold border border-white/10">
            {{ post.post_date|date('d M, Y') }}
        </div>
    </div>

    <!-- Bottom Content Area -->
    <div class="absolute bottom-8 left-8 right-8 z-20">
        <div class="mb-2 text-white/50 text-sm font-bold tracking-widest">
            0{{ loop.index|default('1') }}
        </div>
        <h3 class="text-3xl md:text-4xl font-headline font-extrabold text-white leading-tight tracking-tight pr-16">
            <a href="{{ post.link }}" class="hover:text-primary-fixed transition-colors">
                {{ post.title }}
            </a>
        </h3>
    </div>

    <!-- The Notch (SVG Cutout) -->
    <div class="absolute -bottom-[1px] -right-[1px] w-[8.2rem] h-[8.2rem] z-10 text-[#f1f3ff] dark:text-slate-900/50">
        <svg viewBox="0 0 100 100" class="w-full h-full fill-current">
            <path d="M100 100 L0 100 Q 0 0, 100 0 Z" />
        </svg>
    </div>

    <!-- Action Button (Inside the Notch) -->
    <div class="absolute bottom-4 right-4 w-20 h-20 flex items-center justify-center z-30">
         <div class="w-14 h-14 bg-[#e8e4de] dark:bg-slate-700 rounded-full flex items-center justify-center group-hover:bg-primary group-hover:text-white transition-all duration-300 transform group-hover:scale-110">
            {{ icon('arrow-up-right', 'w-6 h-6 text-on-surface group-hover:text-white') }}
         </div>
    </div>
</article>
