{# views/partials/login-modal.twig #}
<div id="login-modal" role="dialog" aria-modal="true" aria-labelledby="login-modal-title"
     x-show="loginModalOpen"
     x-transition:enter="transition ease-out duration-300"
     x-transition:enter-start="opacity-0"
     x-transition:enter-end="opacity-100"
     x-transition:leave="transition ease-in duration-200"
     x-transition:leave-start="opacity-100"
     x-transition:leave-end="opacity-0"
     class="fixed inset-0 z-[110] flex items-center justify-center p-4 bg-zinc-950/60 backdrop-blur-md"
     @click.self="loginModalOpen = false"
     @keydown.escape.window="loginModalOpen = false"
     x-cloak>
    
    <div class="relative w-full max-w-md bg-white dark:bg-zinc-900 rounded-[2.5rem] shadow-2xl border border-white/20 dark:border-white/5 overflow-hidden transform transition-all"
         x-show="loginModalOpen"
         x-transition:enter="transition ease-out duration-300 delay-100"
         x-transition:enter-start="opacity-0 translate-y-8 scale-95"
         x-transition:enter-end="opacity-100 translate-y-0 scale-100"
         @click.stop>
        
        <!-- Header -->
        <div class="px-8 pt-10 pb-6 text-center">
            <div class="w-16 h-16 bg-red-50 dark:bg-red-900/20 rounded-2xl flex items-center justify-center mx-auto mb-6">
                {{ icon('box-arrow-in-right', 'w-8 h-8 text-primary')|raw }}
            </div>
            <h2 id="login-modal-title" class="text-2xl font-black text-on-surface dark:text-zinc-100 tracking-tight mb-2">Bienvenido de nuevo</h2>
            <p class="text-sm text-slate-500 dark:text-zinc-400">Ingresa tus credenciales para continuar</p>
        </div>

        <!-- Form -->
        <form @submit.prevent="submitLogin()" class="px-8 pb-10 space-y-5">
            <!-- Error Message -->
            <template x-if="authError">
                <div class="p-4 bg-red-50 dark:bg-red-900/20 border border-red-100 dark:border-red-900/30 rounded-2xl flex items-start gap-3">
                    {{ icon('exclamation-circle', 'w-5 h-5 text-red-500')|raw }}
                    <p class="text-xs font-medium text-red-600 dark:text-red-400 leading-snug" x-text="authError"></p>
                </div>
            </template>

            <!-- Success Message -->
            <template x-if="authSuccess">
                <div class="p-4 bg-emerald-50 dark:bg-emerald-900/20 border border-emerald-100 dark:border-emerald-900/30 rounded-2xl flex items-start gap-3">
                    {{ icon('check-circle', 'w-5 h-5 text-emerald-500')|raw }}
                    <p class="text-xs font-medium text-emerald-600 dark:text-emerald-400 leading-snug" x-text="authSuccess"></p>
                </div>
            </template>

            <div class="space-y-4">
                <div class="relative">
                    <span class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">{{ icon('person', 'w-5 h-5')|raw }}</span>
                    <input type="text" 
                           x-model="authForm.username"
                           placeholder="Usuario o Correo"
                           aria-label="Usuario o correo electrónico"
                           autocomplete="username"
                           class="w-full pl-12 pr-4 py-4 bg-slate-50 dark:bg-zinc-800/50 rounded-2xl border border-slate-100 dark:border-zinc-800 text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all dark:text-zinc-200"
                           required>
                </div>

                <div class="relative" x-data="{ show: false }">
                    <span class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">{{ icon('lock', 'w-5 h-5')|raw }}</span>
                    <input :type="show ? 'text' : 'password'" 
                           x-model="authForm.password"
                           placeholder="Contraseña"
                           aria-label="Contraseña"
                           autocomplete="current-password"
                           class="w-full pl-12 pr-12 py-4 bg-slate-50 dark:bg-zinc-800/50 rounded-2xl border border-slate-100 dark:border-zinc-800 text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all dark:text-zinc-200"
                           required>
                    <button type="button" @click="show = !show" class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 hover:text-primary transition-colors" :aria-label="show ? 'Ocultar contraseña' : 'Mostrar contraseña'">
                        <span class="text-xl" x-html="show ? `{{ icon('eye-slash', 'w-5 h-5')|raw|e('js') }}` : `{{ icon('eye', 'w-5 h-5')|raw|e('js') }}`"></span>
                    </button>
                </div>
            </div>

            <div class="flex items-center justify-between px-1">
                <label class="flex items-center gap-2 cursor-pointer group">
                    <div class="relative flex items-center justify-center">
                        <input type="checkbox" x-model="authForm.remember" class="peer appearance-none w-5 h-5 border-2 border-slate-200 dark:border-zinc-700 rounded-lg checked:bg-primary checked:border-primary transition-all">
                        <span class="absolute text-white opacity-0 peer-checked:opacity-100 transition-opacity">{{ icon('check-lg', 'w-3 h-3')|raw }}</span>
                    </div>
                    <span class="text-xs font-bold text-slate-500 dark:text-zinc-400 group-hover:text-primary transition-colors">Recuérdame</span>
                </label>
                <a href="{{ function('wp_lostpassword_url') }}" class="text-xs font-bold text-primary hover:underline">¿Olvido su clave?</a>
            </div>

            <button type="submit" 
                    :disabled="authLoading"
                    class="w-full py-4 bg-primary text-white rounded-2xl font-bold uppercase tracking-widest text-xs shadow-xl shadow-red-900/20 hover:bg-secondary active:scale-95 transition-all disabled:opacity-50 disabled:active:scale-100 flex items-center justify-center gap-2">
                <span x-show="!authLoading">Entrar</span>
                <span x-show="authLoading" class="w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin"></span>
                <span x-show="authLoading" x-text="'Autenticando...'"></span>
            </button>
        </form>

        <!-- Footer -->
        <div class="px-8 py-6 bg-slate-50 dark:bg-zinc-950/30 border-t border-slate-100 dark:border-zinc-800 text-center">
            <p class="text-xs text-slate-500 dark:text-zinc-500">
                ¿No tienes cuenta? <span class="text-primary font-bold">Contacta al administrador</span>
            </p>
        </div>

        <!-- Close Button -->
        <button @click="loginModalOpen = false" class="absolute top-6 right-6 text-slate-400 hover:text-primary transition-colors">
            {{ icon('x-lg', 'w-6 h-6')|raw }}
        </button>
    </div>
</div>
