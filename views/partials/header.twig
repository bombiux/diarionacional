<header class="bg-white/80 dark:bg-slate-900/80 backdrop-blur-xl docked full-width top-0 sticky z-50 shadow-sm dark:shadow-none hidden md:block w-full">
    <div class="flex flex-col w-full max-w-7xl mx-auto px-6 py-4 items-center justify-between gap-4 relative">
        <div class="flex w-full items-center justify-between">
            <!-- Brand Logo -->
            <a href="{{ site.url }}" class="flex items-center group">
                <img src="{{ theme.link }}/assets/img/logo-dn.png" alt="Diario Nacional" class="h-14 w-auto object-contain transition-transform group-hover:scale-105">
            </a>
            <!-- Search & Actions -->
            <div class="flex items-center gap-4">
                <button @click="searchOpen = !searchOpen" aria-label="Search" class="text-on-surface-variant hover:text-primary transition-colors duration-200 flex items-center">
                    <span class="material-symbols-outlined">search</span>
                </button>
                <a aria-label="Facebook" class="text-on-surface-variant hover:text-primary transition-colors duration-200" href="https://www.facebook.com/diarionacional" target="_blank" rel="noopener">
                    <svg class="w-6 h-6 fill-current" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c5.05-.5 9-4.76 9-9.95z"></path>
                    </svg>
                </a>
                <a aria-label="TikTok" class="text-on-surface-variant hover:text-primary transition-colors duration-200" href="#" target="_blank" rel="noopener">
                    <svg class="w-6 h-6 fill-current" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12.525.02c1.31-.02 2.61.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.9-.32-1.89-.23-2.74.24-.81.47-1.4 1.31-1.54 2.22-.16.94.13 1.95.74 2.67.61.73 1.55 1.12 2.49 1.13 1.13.04 2.21-.6 2.78-1.58.26-.45.41-.95.42-1.47V.02z"></path>
                    </svg>
                </a>
                <a aria-label="X" class="text-on-surface-variant hover:text-primary transition-colors duration-200" href="https://x.com/diarionacional" target="_blank" rel="noopener">
                    <svg class="w-5 h-5 fill-current" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path>
                    </svg>
                </a>
            </div>
        </div>
        <!-- Navigation Links -->
        <nav class="w-full flex justify-center gap-8 font-headline font-extrabold tracking-tight text-slate-900 dark:text-slate-100">
            {% set menu_items = (menu ? menu.get_items : null) ?: categories_menu %}
            {% for item in menu_items %}
                <a href="{{ item.link }}" 
                   class="pb-1 transition-all duration-200 {{ item.current ? 'text-primary dark:text-blue-400 border-b-2 border-primary font-bold' : 'text-slate-600 dark:text-slate-400 font-medium hover:text-primary dark:hover:text-blue-300' }}">
                    {{ item.title }}
                </a>
            {% endfor %}
        </nav>
        <!-- Separation Logic -->
        <div class="bg-slate-100 dark:bg-slate-800 h-px w-full absolute bottom-0"></div>
    </div>
</header>

<!-- Header (Mobile) -->
<header class="md:hidden bg-white/80 dark:bg-slate-900/80 backdrop-blur-xl sticky top-0 z-50 shadow-sm w-full">
    <div class="flex items-center justify-between px-6 py-4">
        <button @click="mobileMenuOpen = true" class="text-on-surface-variant">
            <span class="material-symbols-outlined">menu</span>
        </button>
        <a href="{{ site.url }}" class="flex items-center">
            <img src="{{ theme.link }}/assets/img/logo-dn.png" alt="Diario Nacional" class="h-10 w-auto object-contain">
        </a>
        <button @click="searchOpen = !searchOpen" class="text-on-surface-variant">
            <span class="material-symbols-outlined">search</span>
        </button>
    </div>
</header>