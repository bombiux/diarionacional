<div x-show="mobileMenuOpen" 
     x-transition:enter="transition ease-out duration-300"
     x-transition:enter-start="-translate-x-full"
     x-transition:enter-end="translate-x-0"
     x-transition:leave="transition ease-in duration-300"
     x-transition:leave-start="translate-x-0"
     x-transition:leave-end="-translate-x-full"
     class="fixed inset-0 z-[60] md:hidden" 
     x-cloak>
    
    <!-- Backdrop -->
    <div @click="mobileMenuOpen = false" class="absolute inset-0 bg-slate-900/40 backdrop-blur-sm"></div>

    <!-- Menu Content -->
    <div class="relative h-full w-80 flex flex-col p-6 bg-slate-50 dark:bg-slate-950 rounded-r-2xl shadow-2xl overflow-y-auto">
        <div class="mb-8 flex justify-between items-start">
            <div class="flex flex-col gap-2">
                <a href="{{ site.url }}">
                    <img src="{{ theme.link }}/assets/img/logo-dn.png" alt="Diario Nacional" class="h-10 w-auto object-contain">
                </a>
                <h2 class="font-headline font-bold text-lg text-primary-dim dark:text-blue-300">Categorías</h2>
            </div>
            <button @click="mobileMenuOpen = false" class="text-slate-400 hover:text-primary transition-colors">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>

        <nav class="flex flex-col gap-2 font-headline font-bold">
            {% set menu_items = (menu ? menu.get_items : null) ?: categories_menu %}
            {% for item in menu_items %}
                <a class="flex items-center gap-4 px-4 py-3 transition-all rounded-xl {{ item.current ? 'bg-blue-100 dark:bg-blue-900/30 text-primary dark:text-blue-200' : 'text-slate-500 dark:text-slate-400 hover:bg-slate-200 dark:hover:bg-slate-800' }}" 
                   href="{{ item.link }}">
                    {% if item.icon %}
                        <span class="material-symbols-outlined">{{ item.icon }}</span>
                    {% else %}
                        {# Fallback icons based on title if no icon is set #}
                        {% set icon_name = 'article' %}
                        {% if 'nacional' in item.title|lower %}{% set icon_name = 'public' %}
                        {% elseif 'internacional' in item.title|lower %}{% set icon_name = 'language' %}
                        {% elseif 'ambiente' in item.title|lower %}{% set icon_name = 'eco' %}
                        {% elseif 'deporte' in item.title|lower %}{% set icon_name = 'sports_soccer' %}
                        {% elseif 'salud' in item.title|lower %}{% set icon_name = 'medical_services' %}
                        {% elseif 'viral' in item.title|lower %}{% set icon_name = 'bolt' %}
                        {% elseif 'tecnolog' in item.title|lower %}{% set icon_name = 'biotech' %}
                        {% endif %}
                        <span class="material-symbols-outlined">{{ icon_name }}</span>
                    {% endif %}
                    {{ item.title }}
                </a>
            {% endfor %}
        </nav>

        <div class="mt-auto pt-8 flex items-center gap-4 border-t border-slate-200 dark:border-slate-800">
            <a aria-label="Facebook" class="text-on-surface-variant hover:text-primary transition-colors duration-200" href="https://www.facebook.com/diarionacional" target="_blank" rel="noopener">
                <svg class="w-6 h-6 fill-current" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c5.05-.5 9-4.76 9-9.95z"></path>
                </svg>
            </a>
            <a aria-label="X" class="text-on-surface-variant hover:text-primary transition-colors duration-200" href="https://x.com/diarionacional" target="_blank" rel="noopener">
                <svg class="w-5 h-5 fill-current" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path>
                </svg>
            </a>
        </div>
    </div>
</div>