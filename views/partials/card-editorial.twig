<article class="card-pulse group relative flex flex-col h-full bg-surface-container-lowest">
    <!-- Image Section -->
    {% if post.thumbnail %}
    <div class="p-3">
        <div class="aspect-[3/2] overflow-hidden rounded-DEFAULT bg-surface-container-low">
            <img src="{{ post.thumbnail.src('diario-nacional-card')|default(site.theme.link ~ '/assets/img/no-image.jpg') }}" 
                 alt="{{ post.title }}" 
                 class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110">
        </div>
    </div>
    {% endif %}

    <!-- Content Section -->
    <div class="px-6 pb-8 pt-2 flex flex-col flex-grow">
        <div class="flex items-center gap-2 mb-3">
            {% set category = post.terms('category')|first %}
            {% if category %}
            <span class="badge-pill bg-secondary/10 text-secondary">
                {{ category.name }}
            </span>
            {% endif %}
            <span class="label-pulse text-on-surface/30">•</span>
            <span class="label-pulse text-on-surface/40">{{ post.date|date('M d, Y') }}</span>
        </div>

        <h3 class="text-xl md:text-2xl font-headline font-extrabold leading-tight text-on-surface group-hover:text-primary transition-colors mb-4">
            <a href="{{ post.link }}" class="hover:underline decoration-primary/30 underline-offset-4">
                {{ post.title }}
            </a>
        </h3>

        <p class="text-on-surface/60 text-sm line-clamp-3 mb-6 font-sans leading-relaxed">
            {{ post.excerpt|default(post.content|striptags|slice(0, 120) ~ '...') }}
        </p>

        <!-- Spacer to push button to bottom -->
        <div class="mt-auto pt-4 flex items-center justify-between">
            <div class="flex items-center gap-2">
                <div class="w-6 h-6 rounded-full bg-surface-container-high"></div>
                <span class="label-pulse text-on-surface/60 text-[10px]">{{ post.author.name }}</span>
            </div>
            
            <a href="{{ post.link }}" class="text-primary group-hover:translate-x-1 transition-transform">
                {{ icon('arrow-right', 'w-5 h-5') }}
            </a>
        </div>
    </div>
</article>
