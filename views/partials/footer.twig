<footer class="bg-slate-50 dark:bg-slate-950 w-full py-12 px-6 mt-20 flat no-shadows relative">
    <!-- Separation Logic -->
    <div class="bg-slate-200 dark:bg-slate-800 h-px w-full absolute top-0 left-0"></div>
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-8 mt-8">
        <!-- Brand & Copyright -->
        <div class="flex flex-col items-center md:items-start gap-4">
            <a href="{{ site.url }}" class="flex-shrink-0">
                <img src="{{ theme.link }}/assets/img/logo-dn.png" alt="Diario Nacional" class="h-14 w-auto object-contain transition-transform hover:scale-105">
            </a>
            <p class="font-body text-sm tracking-normal text-slate-600 dark:text-slate-400 text-center md:text-left">
                © {{ "now"|date("Y") }} Diario Nacional. Periodismo de alta precisión digital.
            </p>
        </div>
        <!-- Footer Links -->
        <nav class="flex flex-wrap justify-center md:justify-end gap-6 font-body text-sm tracking-normal">
            {% set footer_menu_items = footer_menu.get_items ?: [
                {'title': 'Sobre Nosotros', 'link': '#'},
                {'title': 'Publicidad', 'link': '#'},
                {'title': 'Términos', 'link': '#'},
                {'title': 'Privacidad', 'link': '#'},
                {'title': 'Contacto', 'link': '#'}
            ] %}
            {% for item in footer_menu_items %}
                <a class="text-slate-500 hover:text-primary transition-all duration-300 hover:underline decoration-blue-500 underline-offset-4" href="{{ item.link }}">
                    {{ item.title }}
                </a>
            {% endfor %}
        </nav>
    </div>
</footer>